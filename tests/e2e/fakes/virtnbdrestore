#!/usr/bin/env python3
"""Fake virtnbdrestore that verifies metadata + checksums produced by the fake virtnbdbackup."""

from __future__ import annotations

import argparse
import hashlib
import json
import pathlib
import sys

parser = argparse.ArgumentParser()
parser.add_argument("-i", required=True)
parser.add_argument("-o", required=True)
parser.add_argument("-a", "--action", default="restore", choices=("dump", "restore", "verify"))
# Real virtnbdrestore accepts ``-u``/``--until <checkpoint>`` to stop the
# restore at an intermediate checkpoint. ``restore --at`` composes its output
# into this argument, so the fake must parse and validate it; otherwise the
# e2e covers only verify mode and the whole at→until composition path goes
# untested outside the optional nested-KVM case.
parser.add_argument("-u", "--until", dest="until", default=None)
args, _ = parser.parse_known_args()

source = pathlib.Path(args.i)
if not source.exists():
    print(f"source missing: {source}", file=sys.stderr)
    raise SystemExit(2)


def _known_checkpoints(chain_dir: pathlib.Path) -> set[str]:
    """Mirror libvirt_backup_system.run_records.list_checkpoints.

    Reads the .cpt JSON list first, then checkpoints/*.xml, then the legacy
    top-level *.checkpoint files. The fake validates --until against the
    union so a real virtnbdbackup-style layout (which the fake writes) and
    older fixtures both work.
    """
    names: set[str] = set()
    for cpt in chain_dir.glob("*.cpt"):
        try:
            data = json.loads(cpt.read_text(encoding="utf-8"))
        except (OSError, json.JSONDecodeError):
            continue
        if isinstance(data, list):
            names.update(item for item in data if isinstance(item, str) and item)
    xml_dir = chain_dir / "checkpoints"
    if xml_dir.is_dir():
        names.update(entry.stem for entry in xml_dir.iterdir() if entry.suffix == ".xml")
    names.update(entry.stem for entry in chain_dir.iterdir() if entry.suffix == ".checkpoint")
    return names


# Accept both the explicit v2.x ``-a verify`` form and the legacy ``-o verify``
# shortcut so the fake stays compatible with anything the runtime may invoke.
mode = "verify" if args.action == "verify" or args.o == "verify" else args.action

if args.until is not None:
    known = _known_checkpoints(source)
    if args.until not in known:
        print(
            f"--until {args.until!r} is not a known checkpoint in {source} (known: {sorted(known)})",
            file=sys.stderr,
        )
        raise SystemExit(8)

if mode == "restore":
    # Real virtnbdrestore writes restored disk images under -o. The fake
    # emits a single sentinel file per chain so the e2e can assert the
    # destination was populated without re-implementing image rebuild.
    output = pathlib.Path(args.o)
    output.mkdir(parents=True, exist_ok=True)
    receipt = {
        "source": str(source),
        "until": args.until,
        "action": "restore",
    }
    (output / "restore-receipt.json").write_text(
        json.dumps(receipt, sort_keys=True), encoding="utf-8"
    )
    target = args.until or "<chain-end>"
    print(f"restored from {source} to {output} (until={target})")
    raise SystemExit(0)

if mode != "verify":
    print(f"unsupported restore mode: {mode}", file=sys.stderr)
    raise SystemExit(2)

metadata_path = source / "metadata.json"
if not metadata_path.exists():
    print(f"missing metadata.json in {source}", file=sys.stderr)
    raise SystemExit(3)

try:
    metadata = json.loads(metadata_path.read_text(encoding="utf-8"))
except json.JSONDecodeError as exc:
    print(f"metadata.json is not valid JSON: {exc}", file=sys.stderr)
    raise SystemExit(3) from exc

checkpoint = metadata.get("checkpoint", "")
if not checkpoint or not (source / f"{checkpoint}.checkpoint").exists():
    print(f"checkpoint file missing for {checkpoint!r}", file=sys.stderr)
    raise SystemExit(4)

for disk in metadata.get("disks", []):
    disk_path = source / disk["file"]
    if not disk_path.exists():
        print(f"missing disk file {disk_path}", file=sys.stderr)
        raise SystemExit(5)
    payload = disk_path.read_bytes()
    if len(payload) != disk["size"]:
        print(f"size mismatch for {disk_path}", file=sys.stderr)
        raise SystemExit(6)
    actual = hashlib.sha256(payload).hexdigest()
    if actual != disk["sha256"]:
        print(f"checksum mismatch for {disk_path}: expected {disk['sha256']}, got {actual}", file=sys.stderr)
        raise SystemExit(7)

print(f"verify ok ({len(metadata.get('disks', []))} disks, level={metadata.get('level')})")
