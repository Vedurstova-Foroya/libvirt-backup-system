#!/usr/bin/env python3
"""Fake virtnbdbackup that emits enough metadata/checkpoint info to be verified."""

from __future__ import annotations

import argparse
import hashlib
import json
import os
import pathlib
import secrets
import sys

if len(sys.argv) == 2 and sys.argv[1] in {"--version", "-v"}:
    print("virtnbdbackup 2.46")
    raise SystemExit(0)

parser = argparse.ArgumentParser()
parser.add_argument("-U", required=True)
parser.add_argument("-d", required=True)
parser.add_argument("-l", required=True, choices=["full", "auto", "inc"])
parser.add_argument("-o", required=True)
parser.add_argument("--compress", action="store_true")
args, _ = parser.parse_known_args()

if not args.U.startswith(("qemu:", "test:")):
    print(f"unsupported libvirt URI: {args.U}", file=sys.stderr)
    raise SystemExit(2)

if not args.d or args.d.startswith("-") or "/" in args.d or args.d in {".", ".."}:
    print(f"unsafe VM name: {args.d!r}", file=sys.stderr)
    raise SystemExit(2)

if os.environ.get("FAIL_BACKUP_FOR") == args.d:
    print(f"simulated backup failure for {args.d}", file=sys.stderr)
    raise SystemExit(7)

dest = pathlib.Path(args.o)
dest.mkdir(parents=True, exist_ok=True)

disk_payload = f"disk-data:{args.d}:{args.l}:{secrets.token_hex(4)}".encode()
# Real virtnbdbackup encodes the backup level into the data filename
# (``vda.full.data`` or ``vda.inc.virtnbdbackup.<N>.data``). Mirror that here
# so retention's full-backup gate sees the right shape.
existing_incs = len(list(dest.glob("vda.inc.virtnbdbackup.*.data")))
if args.l == "inc":
    disk_file = dest / f"vda.inc.virtnbdbackup.{existing_incs}.data"
else:
    disk_file = dest / f"vda.{args.l}.data"
disk_file.write_bytes(disk_payload)

checkpoint_name = f"virtnbdbackup.{args.d}.{secrets.token_hex(4)}"
metadata = {
    "domain": args.d,
    "level": args.l,
    "compressed": args.compress,
    "checkpoint": checkpoint_name,
    "disks": [
        {
            "target": "sda",
            "file": disk_file.name,
            "size": len(disk_payload),
            "sha256": hashlib.sha256(disk_payload).hexdigest(),
        }
    ],
}
(dest / "metadata.json").write_text(json.dumps(metadata, indent=2, sort_keys=True), encoding="utf-8")
# Mirror real virtnbdbackup's authoritative checkpoint state: append the new
# checkpoint to <domain>.cpt (JSON list, see
# libvirtnbdbackup/virt/checkpoint.py:save) and drop the per-checkpoint XML
# under <output>/checkpoints/.
cpt_path = dest / f"{args.d}.cpt"
try:
    existing_checkpoints = json.loads(cpt_path.read_text(encoding="utf-8"))
    if not isinstance(existing_checkpoints, list):
        existing_checkpoints = []
except (OSError, json.JSONDecodeError):
    existing_checkpoints = []
existing_checkpoints.append(checkpoint_name)
cpt_path.write_text(json.dumps(existing_checkpoints), encoding="utf-8")
(dest / "checkpoints").mkdir(exist_ok=True)
(dest / "checkpoints" / f"{checkpoint_name}.xml").write_text(
    f"<domaincheckpoint><name>{checkpoint_name}</name></domaincheckpoint>\n",
    encoding="utf-8",
)
print(f"backed up {args.d} level={args.l} to {dest}")
