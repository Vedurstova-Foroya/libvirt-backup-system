#!/usr/bin/env python3
import os
import pathlib
import sys

args = sys.argv[1:]
vm = args[args.index("-d") + 1] if "-d" in args else "unknown"
if os.environ.get("FAIL_BACKUP_FOR") == vm:
    print(f"simulated backup failure for {vm}", file=sys.stderr)
    raise SystemExit(7)
dest = pathlib.Path(args[args.index("-o") + 1])
dest.mkdir(parents=True, exist_ok=True)
(dest / f"{vm}.backup").write_text("backup artifact\n", encoding="utf-8")
print(f"backed up {vm} to {dest}")
