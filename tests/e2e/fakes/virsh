#!/usr/bin/env python3
import sys

args = sys.argv[1:]
if "list" in args and "--name" in args:
    print("alpha")
    print("beta")
    print("ignore-me")
    raise SystemExit(0)
if "domstate" in args:
    name = args[-1]
    if name == "alpha":
        print("running")
    elif name in {"beta", "ignore-me"}:
        print("shut off")
    else:
        raise SystemExit(1)
    raise SystemExit(0)
raise SystemExit(0)
