#!/usr/bin/env python3
import sys

args = sys.argv[1:]
UUIDS = {
    "alpha": "aaaaaaaa-aaaa-aaaa-aaaa-aaaaaaaaaaaa",
    "beta": "bbbbbbbb-bbbb-bbbb-bbbb-bbbbbbbbbbbb",
    "ignore-me": "cccccccc-cccc-cccc-cccc-cccccccccccc",
}
DOMAINS = ("alpha", "beta", "ignore-me")
if "list" in args and "--name" in args:
    # list_vms now batches name+uuid through a single ``virsh list --all
    # --uuid --name`` invocation. Real virsh prints ``<uuid>   <name>`` rows
    # in that mode; the fake mirrors the same shape when both flags appear.
    if "--uuid" in args:
        for name in DOMAINS:
            print(f"{UUIDS[name]} {name}")
    else:
        for name in DOMAINS:
            print(name)
    raise SystemExit(0)
if "domstate" in args:
    name = args[-1]
    if name == "alpha":
        print("running")
    elif name in {"beta", "ignore-me"}:
        print("shut off")
    else:
        raise SystemExit(1)
    raise SystemExit(0)
if "domuuid" in args:
    name = args[-1]
    if name not in UUIDS:
        raise SystemExit(1)
    print(UUIDS[name])
    raise SystemExit(0)
if "dumpxml" in args:
    name = args[-1]
    if name not in DOMAINS:
        raise SystemExit(1)
    print(
        f"<domain>"
        f"<devices>"
        f"<disk type='file' device='disk'>"
        f"<source file='/var/lib/libvirt/images/{name}.qcow2'/>"
        f"</disk>"
        f"</devices>"
        f"</domain>"
    )
    raise SystemExit(0)
raise SystemExit(0)
